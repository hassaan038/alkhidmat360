# Local Development Environment Configuration
# Copy this to .env for local development (not for Docker)
# For Docker, use .env.docker files which are already configured

# Database (for local MySQL installation)
DATABASE_URL="mysql://root:#Sohail922@localhost:3306/alkhidmat360"

# Server
PORT=5000
NODE_ENV=development

# Session (same as production for local testing)
SESSION_SECRET="docker-secret-key-change-in-production"
SESSION_NAME="alkhidmat_sid"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Chatbot (Google Gemini)
# Get a key from https://aistudio.google.com/apikey and paste it here:
GEMINI_API_KEY=""
# Optional model override (default: gemini-3-flash-preview):
# GEMINI_MODEL="gemini-3-flash-preview"

# Email notifications (SMTP) — for status-update emails to users
# For Gmail: enable 2FA on the account, then create an App Password at
# https://myaccount.google.com/apppasswords and paste the 16-char password below.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Alkhidmat 360 <noreply@alkhidmat360.com>"
