// Prisma Schema for Alkhidmat 360
// Database: MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

enum UserType {
  DONOR
  BENEFICIARY
  VOLUNTEER
  ADMIN
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String   // hashed with bcrypt
  fullName      String
  phoneNumber   String
  cnic          String?  @unique
  userType      UserType
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  qurbaniDonations      QurbaniDonation[]
  rationDonations       RationDonation[]
  skinCollections       SkinCollection[]
  orphanSponsorships    OrphanSponsorship[]
  loanApplications      LoanApplication[]
  ramadanRations        RamadanRationApplication[]
  orphanRegistrations   OrphanRegistration[]
  volunteerTasks        VolunteerTask[]
  qurbaniHissaBookings  QurbaniHissaBooking[]
  qurbaniSkinPickups    QurbaniSkinPickup[]

  @@index([email])
  @@index([userType])
}

// ============================================
// DONOR FORMS
// ============================================

enum QurbaniAnimalType {
  GOAT
  COW
  CAMEL
}

model QurbaniDonation {
  id            Int                 @id @default(autoincrement())
  userId        Int
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  animalType    QurbaniAnimalType
  quantity      Int
  totalAmount   Decimal             @db.Decimal(10, 2)
  donorName     String
  donorPhone    String
  donorAddress  String              @db.Text
  deliveryDate  DateTime?
  notes         String?             @db.Text

  status        String              @default("pending") // pending, confirmed, completed, rejected
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([status])
}

model RationDonation {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  donorName     String
  donorPhone    String
  donorEmail    String
  amount        Decimal  @db.Decimal(10, 2)
  rationItems   String?  @db.Text // JSON string of items if specific
  notes         String?  @db.Text

  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model SkinCollection {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  donorName         String
  donorPhone        String
  collectionAddress String   @db.Text
  numberOfSkins     Int
  animalType        String   // goat, cow, camel, etc.
  preferredDate     DateTime
  notes             String?  @db.Text

  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrphanSponsorship {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sponsorName      String
  sponsorPhone     String
  sponsorEmail     String
  monthlyAmount    Decimal  @db.Decimal(10, 2)
  duration         Int      // months
  orphanAge        String?  // preference: "child", "teen", "any"
  orphanGender     String?  // preference: "male", "female", "any"
  startDate        DateTime?
  notes            String?  @db.Text

  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// BENEFICIARY FORMS
// ============================================

enum LoanType {
  INTEREST_FREE
  BUSINESS
  EDUCATION
  MEDICAL
  HOUSING
  MARRIAGE
  OTHER
}

model LoanApplication {
  id                    Int      @id @default(autoincrement())
  userId                Int
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  loanType              LoanType
  requestedAmount       Decimal  @db.Decimal(10, 2)
  monthlyIncome         Decimal  @db.Decimal(10, 2)
  familyMembers         Int
  employmentStatus      String
  purposeDescription    String   @db.Text
  applicantName         String
  applicantPhone        String
  applicantCNIC         String
  applicantAddress      String   @db.Text
  guarantorName         String?
  guarantorPhone        String?
  guarantorCNIC         String?
  guarantorAddress      String?  @db.Text
  additionalNotes       String?  @db.Text

  status                String   @default("pending") // pending, under_review, approved, rejected
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model RamadanRationApplication {
  id                    Int      @id @default(autoincrement())
  userId                Int
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  familyMembers         Int
  monthlyIncome         Decimal  @db.Decimal(10, 2)
  hasDisabledMembers    Boolean
  disabilityDetails     String?  @db.Text
  applicantName         String
  applicantPhone        String
  applicantCNIC         String
  applicantAddress      String   @db.Text
  reasonForApplication  String   @db.Text
  previouslyReceived    Boolean
  additionalNotes       String?  @db.Text

  status                String   @default("pending")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrphanRegistration {
  id                  Int      @id @default(autoincrement())
  userId              Int
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  orphanName          String
  orphanAge           Int
  orphanGender        String
  guardianRelation    String
  guardianName        String
  guardianPhone       String
  guardianCNIC        String
  guardianAddress     String   @db.Text
  monthlyIncome       Decimal  @db.Decimal(10, 2)
  familyMembers       Int
  educationLevel      String
  schoolName          String?
  healthCondition     String?  @db.Text
  fatherStatus        String
  motherStatus        String
  additionalNotes     String?  @db.Text

  status              String   @default("pending")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// VOLUNTEER FORMS
// ============================================

enum TaskCategory {
  DISTRIBUTION
  FUNDRAISING
  AWARENESS
  ADMINISTRATIVE
  FIELD_WORK
  EVENT_SUPPORT
}

model VolunteerTask {
  id                  Int          @id @default(autoincrement())
  userId              Int
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  volunteerName       String
  volunteerPhone      String
  volunteerEmail      String
  volunteerAddress    String       @db.Text
  taskCategory        TaskCategory
  availability        String       // JSON: ["monday", "saturday"]
  skills              String?      @db.Text
  experience          String?      @db.Text
  preferredLocation   String?
  emergencyContact    String

  status              String       @default("pending")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([taskCategory])
}

// ============================================
// QURBANI MODULE (seasonal — Eid-ul-Adha)
// ============================================

// Generic key-value store for feature flags and global config.
model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
  updatedBy Int?
}

enum QurbaniListingStatus {
  DRAFT
  ACTIVE
  FULL
  CLOSED
}

model QurbaniListing {
  id              Int                  @id @default(autoincrement())
  name            String?
  weightKg        Decimal?             @db.Decimal(10, 2)
  totalHissas     Int                  @default(7)
  pricePerHissa   Decimal              @db.Decimal(10, 2)
  photoUrl        String?
  pickupDate      DateTime
  pickupLocation  String               @db.Text
  description     String?              @db.Text
  status          QurbaniListingStatus @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  bookings        QurbaniHissaBooking[]

  @@index([status])
}

model QurbaniHissaBooking {
  id              Int      @id @default(autoincrement())
  listingId       Int
  listing         QurbaniListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  hissaCount      Int
  dedications     String   @db.Text // JSON array: [{ hissaNumber, dedicatedTo }]
  totalAmount     Decimal  @db.Decimal(10, 2)
  paymentMarked   Boolean  @default(false)
  paymentMarkedAt DateTime?
  notes           String?  @db.Text

  status          String   @default("pending") // pending, confirmed, rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([listingId])
  @@index([userId])
  @@index([status])
}

// Skin pickup requests — same flag as Qurbani Booking, available to any
// authenticated user. Lightweight form: contact + address (with optional
// GPS coords) + a few details. Distinct from the existing donor-only
// SkinCollection model.
model QurbaniSkinPickup {
  id                Int       @id @default(autoincrement())
  userId            Int
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  contactPhone      String
  address           String    @db.Text
  latitude          Decimal?  @db.Decimal(10, 7)
  longitude         Decimal?  @db.Decimal(10, 7)
  numberOfSkins     Int       @default(1)
  preferredDate     DateTime?
  additionalDetails String?   @db.Text

  status            String    @default("pending") // pending, scheduled, collected, cancelled
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// SESSIONS (managed at runtime by express-mysql-session)
// ============================================
// This model mirrors the actual `sessions` table that express-mysql-session
// auto-creates on boot. Prisma does not write to it — declared here only so
// `prisma migrate dev` does not detect drift.
model Session {
  sessionId String  @id @map("session_id") @db.VarChar(128)
  expires   Int     @db.UnsignedInt
  data      String? @db.MediumText

  @@map("sessions")
}
