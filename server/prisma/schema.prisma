// Prisma Schema for Alkhidmat 360
// Database: MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

enum UserType {
  DONOR
  BENEFICIARY
  VOLUNTEER
  ADMIN
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String   // hashed with bcrypt
  fullName      String
  phoneNumber   String
  cnic          String?  @unique
  userType      UserType
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  qurbaniDonations      QurbaniDonation[]
  rationDonations       RationDonation[]
  skinCollections       SkinCollection[]
  orphanSponsorships    OrphanSponsorship[]
  loanApplications      LoanApplication[]
  ramadanRations        RamadanRationApplication[]
  orphanRegistrations   OrphanRegistration[]
  volunteerTasks        VolunteerTask[]
  qurbaniHissaBookings  QurbaniHissaBooking[]
  qurbaniSkinPickups    QurbaniSkinPickup[]
  fitranaCollections    Fitrana[]
  zakatPayments         ZakatPayment[]
  zakatApplications     ZakatApplication[]

  @@index([email])
  @@index([userType])
}

// ============================================
// DONOR FORMS
// ============================================

enum QurbaniAnimalType {
  GOAT
  COW
  CAMEL
}

model QurbaniDonation {
  id            Int                 @id @default(autoincrement())
  userId        Int
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  animalType    QurbaniAnimalType
  quantity      Int
  totalAmount   Decimal             @db.Decimal(10, 2)
  donorName     String
  donorPhone    String
  donorAddress  String              @db.Text
  deliveryDate  DateTime?
  notes         String?             @db.Text

  status        String              @default("pending") // pending, confirmed, completed, rejected
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([status])
}

model RationDonation {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  donorName     String
  donorPhone    String
  donorEmail    String
  amount        Decimal  @db.Decimal(10, 2)
  rationItems   String?  @db.Text // JSON string of items if specific
  notes         String?  @db.Text

  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model SkinCollection {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  donorName         String
  donorPhone        String
  collectionAddress String   @db.Text
  numberOfSkins     Int
  animalType        String   // goat, cow, camel, etc.
  preferredDate     DateTime
  notes             String?  @db.Text

  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrphanSponsorship {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  sponsorName      String
  sponsorPhone     String
  sponsorEmail     String
  monthlyAmount    Decimal  @db.Decimal(10, 2)
  duration         Int      // months
  orphanAge        String?  // preference: "child", "teen", "any"
  orphanGender     String?  // preference: "male", "female", "any"
  startDate        DateTime?
  notes            String?  @db.Text

  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// BENEFICIARY FORMS
// ============================================

enum LoanType {
  INTEREST_FREE
  BUSINESS
  EDUCATION
  MEDICAL
  HOUSING
  MARRIAGE
  OTHER
}

model LoanApplication {
  id                    Int      @id @default(autoincrement())
  userId                Int
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  loanType              LoanType
  requestedAmount       Decimal  @db.Decimal(10, 2)
  monthlyIncome         Decimal  @db.Decimal(10, 2)
  familyMembers         Int
  employmentStatus      String
  purposeDescription    String   @db.Text
  applicantName         String
  applicantPhone        String
  applicantCNIC         String
  applicantAddress      String   @db.Text
  guarantorName         String?
  guarantorPhone        String?
  guarantorCNIC         String?
  guarantorAddress      String?  @db.Text
  additionalNotes       String?  @db.Text

  status                String   @default("pending") // pending, under_review, approved, rejected
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model RamadanRationApplication {
  id                    Int      @id @default(autoincrement())
  userId                Int
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  familyMembers         Int
  monthlyIncome         Decimal  @db.Decimal(10, 2)
  hasDisabledMembers    Boolean
  disabilityDetails     String?  @db.Text
  applicantName         String
  applicantPhone        String
  applicantCNIC         String
  applicantAddress      String   @db.Text
  reasonForApplication  String   @db.Text
  previouslyReceived    Boolean
  additionalNotes       String?  @db.Text

  status                String   @default("pending")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrphanRegistration {
  id                  Int      @id @default(autoincrement())
  userId              Int
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  orphanName          String
  orphanAge           Int
  orphanGender        String
  guardianRelation    String
  guardianName        String
  guardianPhone       String
  guardianCNIC        String
  guardianAddress     String   @db.Text
  monthlyIncome       Decimal  @db.Decimal(10, 2)
  familyMembers       Int
  educationLevel      String
  schoolName          String?
  healthCondition     String?  @db.Text
  fatherStatus        String
  motherStatus        String
  additionalNotes     String?  @db.Text

  status              String   @default("pending")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// VOLUNTEER FORMS
// ============================================

enum TaskCategory {
  DISTRIBUTION
  FUNDRAISING
  AWARENESS
  ADMINISTRATIVE
  FIELD_WORK
  EVENT_SUPPORT
}

model VolunteerTask {
  id                  Int          @id @default(autoincrement())
  userId              Int
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  volunteerName       String
  volunteerPhone      String
  volunteerEmail      String
  volunteerAddress    String       @db.Text
  taskCategory        TaskCategory
  availability        String       // JSON: ["monday", "saturday"]
  skills              String?      @db.Text
  experience          String?      @db.Text
  preferredLocation   String?
  emergencyContact    String

  status              String       @default("pending")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([taskCategory])
}

// ============================================
// QURBANI MODULE (seasonal — Eid-ul-Adha)
// ============================================

// Generic key-value store for feature flags and global config.
model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
  updatedBy Int?
}

enum QurbaniListingStatus {
  DRAFT
  ACTIVE
  FULL
  CLOSED
}

model QurbaniListing {
  id              Int                  @id @default(autoincrement())
  name            String?
  weightKg        Decimal?             @db.Decimal(10, 2)
  totalHissas     Int                  @default(7)
  pricePerHissa   Decimal              @db.Decimal(10, 2)
  photoUrl        String?
  pickupDate      DateTime
  pickupLocation  String               @db.Text
  description     String?              @db.Text
  status          QurbaniListingStatus @default(DRAFT)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  bookings        QurbaniHissaBooking[]

  @@index([status])
}

model QurbaniHissaBooking {
  id              Int      @id @default(autoincrement())
  listingId       Int
  listing         QurbaniListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  hissaCount      Int
  dedications     String   @db.Text // JSON array: [{ hissaNumber, dedicatedTo }]
  totalAmount     Decimal  @db.Decimal(10, 2)
  paymentMarked   Boolean  @default(false)
  paymentMarkedAt DateTime?
  paymentScreenshotUrl String? // /uploads/payments/<file> — optional proof
  notes           String?  @db.Text

  status          String   @default("pending") // pending, confirmed, rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([listingId])
  @@index([userId])
  @@index([status])
}

// Skin pickup requests — same flag as Qurbani Booking, available to any
// authenticated user. Lightweight form: contact + address (with optional
// GPS coords) + a few details. Distinct from the existing donor-only
// SkinCollection model.
model QurbaniSkinPickup {
  id                Int       @id @default(autoincrement())
  userId            Int
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  contactPhone      String
  address           String    @db.Text
  latitude          Decimal?  @db.Decimal(10, 7)
  longitude         Decimal?  @db.Decimal(10, 7)
  numberOfSkins     Int       @default(1)
  preferredDate     DateTime?
  additionalDetails String?   @db.Text
  housePhotoUrl     String?   // optional photo of the house/landmark, served from /uploads/skin-pickup/

  status            String    @default("pending") // pending, scheduled, collected, cancelled
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// Fitrana (Sadaqat al-Fitr) — calculated per family member, payable
// before Eid prayer. Traditionally tied to Eid-ul-Fitr but currently
// gated by the same qurbani_module_enabled flag in this app.
//
// calculationBasis is a free string ('wheat' | 'barley' | 'dates' |
// 'raisins' | 'alkhidmat' | 'custom') so adding new bases later does
// not require a migration. amountPerPerson is what was used at the
// time of submission (rates change yearly).
model Fitrana {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  numberOfPeople  Int
  calculationBasis String
  amountPerPerson Decimal   @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(10, 2)
  contactPhone    String?
  notes           String?   @db.Text

  paymentMarked   Boolean   @default(false)
  paymentMarkedAt DateTime?
  paymentScreenshotUrl String? // /uploads/payments/<file> — optional proof

  status          String    @default("pending") // pending, confirmed, rejected
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// Zakat payment (donor) — calculator-driven submission with the same
// deferred-write payment flow as fitrana. Year-round, NOT gated by the
// qurbani flag. The detailed breakdown is preserved so the donor (and
// admin) have a record of what was declared at submission time.
model ZakatPayment {
  id               Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  cashSavings      Decimal   @db.Decimal(15, 2) @default(0)
  goldGrams        Decimal   @db.Decimal(10, 3) @default(0)
  goldValue        Decimal   @db.Decimal(15, 2) @default(0)   // PKR equivalent of goldGrams
  silverGrams      Decimal   @db.Decimal(10, 3) @default(0)
  silverValue      Decimal   @db.Decimal(15, 2) @default(0)
  investments      Decimal   @db.Decimal(15, 2) @default(0)
  businessAssets   Decimal   @db.Decimal(15, 2) @default(0)
  otherAssets      Decimal   @db.Decimal(15, 2) @default(0)
  liabilities      Decimal   @db.Decimal(15, 2) @default(0)

  nisabBasis       String                                     // 'gold' | 'silver'
  nisabThreshold   Decimal   @db.Decimal(15, 2)               // PKR snapshot
  totalWealth      Decimal   @db.Decimal(15, 2)               // sum of zakatable - liabilities
  zakatAmount      Decimal   @db.Decimal(15, 2)               // 2.5% of totalWealth (or 0 if below nisab)

  contactPhone     String?
  notes            String?   @db.Text

  paymentMarked    Boolean   @default(false)
  paymentMarkedAt  DateTime?
  paymentScreenshotUrl String?

  status           String    @default("pending")              // pending, confirmed, rejected
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// Zakat application (beneficiary) — request to be considered eligible
// for zakat assistance. Reviewed by admins; status flow follows the
// same pending → under_review → approved/rejected pattern as the
// existing beneficiary forms.
model ZakatApplication {
  id                 Int      @id @default(autoincrement())
  userId             Int
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  applicantName      String
  applicantPhone     String
  applicantCNIC      String                                  // 13 digits (no dashes)
  applicantAddress   String   @db.Text

  familyMembers      Int
  monthlyIncome      Decimal  @db.Decimal(10, 2)
  employmentStatus   String                                  // employed | self-employed | unemployed | student | retired | other
  housingStatus      String                                  // own | rent | family | other
  hasDisabledMembers Boolean
  disabilityDetails  String?  @db.Text

  reasonForApplication String @db.Text
  amountRequested    Decimal? @db.Decimal(10, 2)
  additionalNotes    String?  @db.Text
  cnicDocumentUrl    String?                                 // optional CNIC photo, /uploads/zakat-docs/<file>

  status             String   @default("pending")            // pending, under_review, approved, rejected
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// SESSIONS (managed at runtime by express-mysql-session)
// ============================================
// This model mirrors the actual `sessions` table that express-mysql-session
// auto-creates on boot. Prisma does not write to it — declared here only so
// `prisma migrate dev` does not detect drift.
model Session {
  sessionId String  @id @map("session_id") @db.VarChar(128)
  expires   Int     @db.UnsignedInt
  data      String? @db.MediumText

  @@map("sessions")
}
